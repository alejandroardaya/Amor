<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Te amo mi amor 💛</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <div id="gameContainer">
    <!-- Canvas donde se dibuja todo el juego -->
    <canvas id="gameCanvas" width="800" height="400"></canvas>

    <!-- Mensaje final, oculto hasta ganar -->
    <div id="winMessage" class="hidden">
      <p>Te amo mi amor</p>
      <span class="heartIcon">💛</span>
    </div>

    <!-- Botón táctil para saltar (celulares) -->
    <button id="jumpButton">SALTAR</button>
  </div>

  <p class="hint">Presioná la barra espaciadora o el botón para saltar</p>

  <script src="script.js"></script>
</body>
</html>
